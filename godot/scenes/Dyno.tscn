[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/dyno_ui.gd" id="1"]
[ext_resource type="Script" path="res://scripts/dyno_controller.py" id="2"]
[ext_resource type="Script" path="res://scripts/dyno_graph.gd" id="3"]
[ext_resource type="Script" path="res://scripts/dyno_audio.gd" id="4"]

[node name="Dyno" type="Control"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

[node name="DynoController" type="Node" parent="."]
script = ExtResource("2")

[node name="DynoAudio" type="AudioStreamPlayer" parent="."]
script = ExtResource("4")

[node name="Layout" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = 16.0
offset_right = -16.0
offset_bottom = -16.0
theme_override_constants/separation = 10

[node name="SetupSection" type="VBoxContainer" parent="Layout"]
layout_mode = 2

[node name="SetupLabel" type="Label" parent="Layout/SetupSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Setup (Car + Drivetrain)"

[node name="CarRow" type="HBoxContainer" parent="Layout/SetupSection"]
layout_mode = 2

[node name="CarLabel" type="Label" parent="Layout/SetupSection/CarRow"]
layout_mode = 2
custom_minimum_size = Vector2(160, 0)
text = "Car"

[node name="CarOption" type="OptionButton" parent="Layout/SetupSection/CarRow"]
custom_minimum_size = Vector2(320, 0)
layout_mode = 2

[node name="TurboRow" type="HBoxContainer" parent="Layout/SetupSection"]
layout_mode = 2

[node name="TurboLabel" type="Label" parent="Layout/SetupSection/TurboRow"]
layout_mode = 2
custom_minimum_size = Vector2(160, 0)
text = "Turbo"

[node name="TurboOption" type="OptionButton" parent="Layout/SetupSection/TurboRow"]
custom_minimum_size = Vector2(320, 0)
layout_mode = 2

[node name="ModeRow" type="HBoxContainer" parent="Layout/SetupSection"]
layout_mode = 2

[node name="ModeCheckBox" type="CheckBox" parent="Layout/SetupSection/ModeRow"]
layout_mode = 2
text = "Chassis Dyno (clutch/gearbox/tires)"

[node name="TireOption" type="OptionButton" parent="Layout/SetupSection/ModeRow"]
custom_minimum_size = Vector2(280, 0)
layout_mode = 2

[node name="GearRow" type="HBoxContainer" parent="Layout/SetupSection"]
layout_mode = 2

[node name="GearLabel" type="Label" parent="Layout/SetupSection/GearRow"]
layout_mode = 2
custom_minimum_size = Vector2(160, 0)
text = "Gear"

[node name="TransmissionOption" type="OptionButton" parent="Layout/SetupSection/GearRow"]
custom_minimum_size = Vector2(280, 0)
layout_mode = 2

[node name="ShiftDownButton" type="Button" parent="Layout/SetupSection/GearRow"]
layout_mode = 2
text = "-"

[node name="GearValue" type="Label" parent="Layout/SetupSection/GearRow"]
layout_mode = 2
custom_minimum_size = Vector2(100, 0)
horizontal_alignment = 1
text = "N"

[node name="ShiftUpButton" type="Button" parent="Layout/SetupSection/GearRow"]
layout_mode = 2
text = "+"

[node name="Sep1" type="HSeparator" parent="Layout"]
layout_mode = 2

[node name="TuningSection" type="VBoxContainer" parent="Layout"]
layout_mode = 2

[node name="TuningLabel" type="Label" parent="Layout/TuningSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Tuning"

[node name="BoostRow" type="HBoxContainer" parent="Layout/TuningSection"]
layout_mode = 2

[node name="BoostTargetLabel" type="Label" parent="Layout/TuningSection/BoostRow"]
layout_mode = 2
custom_minimum_size = Vector2(160, 0)
text = "Target Boost: 100%"

[node name="BoostSlider" type="HSlider" parent="Layout/TuningSection/BoostRow"]
custom_minimum_size = Vector2(320, 0)
layout_mode = 2
max_value = 100.0
step = 1.0
value = 100.0

[node name="AfrRow" type="HBoxContainer" parent="Layout/TuningSection"]
layout_mode = 2

[node name="AfrCheckBox" type="CheckBox" parent="Layout/TuningSection/AfrRow"]
layout_mode = 2
text = "Override target AFR"

[node name="AfrSlider" type="HSlider" parent="Layout/TuningSection/AfrRow"]
custom_minimum_size = Vector2(280, 0)
layout_mode = 2
min_value = 10.0
max_value = 16.0
step = 0.1
value = 12.5
editable = false

[node name="AfrValueLabel" type="Label" parent="Layout/TuningSection/AfrRow"]
layout_mode = 2
custom_minimum_size = Vector2(60, 0)
text = "12.5"

[node name="Sep3" type="HSeparator" parent="Layout"]
layout_mode = 2

[node name="RunSection" type="VBoxContainer" parent="Layout"]
layout_mode = 2

[node name="RunLabel" type="Label" parent="Layout/RunSection"]
layout_mode = 2
