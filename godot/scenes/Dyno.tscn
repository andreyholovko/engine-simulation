[connection signal="item_selected" from="Layout/SetupSection/CarRow/CarOption" to="." method="_on_car_selected"]
[connection signal="item_selected" from="Layout/SetupSection/TurboRow/TurboOption" to="." method="_on_turbo_selected"]
