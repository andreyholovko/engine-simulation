text = "Run"

[node name="PowerPullRow" type="HBoxContainer" parent="Layout/RunSection"]
layout_mode = 2

[node name="PowerPullButton" type="Button" parent="Layout/RunSection/PowerPullRow"]
layout_mode = 2
text = "Start Power Pull"

[node name="FinishPullButton" type="Button" parent="Layout/RunSection/PowerPullRow"]
layout_mode = 2
